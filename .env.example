# Copy to .env and adjust (Docker Compose loads .env automatically for variable substitution)
#   cp .env.example .env

# --- Demo (default): no key ---
ECOSCALE_CARBON_API=mock

# --- Live UK grid (FREE, no key) — use with docker compose ---
# ECOSCALE_CARBON_API=carbonintensity

# --- Live global zones (needs API key from app.electricitymaps.com) ---
# ECOSCALE_CARBON_API=electricitymaps
# ECOSCALE_CARBON_API_KEY=your_token_here

ECOSCALE_IN_CLUSTER=false
